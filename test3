$arquivo = "C:\Users\calyme.santos\Documents\tonersTEST.xlsx"

$excel = New-Object -ComObject Excel.Application
$excel.Visible = $true

$workbook = $excel.Workbooks.Open($arquivo)

$sheet = $workbook.Worksheets.Item(1)
$historico = $workbook.Worksheets.Item("HISTORICO")

function Registrar-Historico($tipo,$toner,$quantidade){

    $linha = $historico.UsedRange.Rows.Count + 1

    $historico.Cells.Item($linha,1) = Get-Date -Format "dd/MM/yyyy HH:mm"
    $historico.Cells.Item($linha,2) = $tipo
    $historico.Cells.Item($linha,3) = $toner
    $historico.Cells.Item($linha,4) = $quantidade
}

while ($true){

    Write-Host ""
    Write-Host "=== CONTROLE DE TONERS ==="
    Write-Host "1 - Entrada de toner"
    Write-Host "2 - Saida de toner"
    Write-Host "3 - Ver estoque"
    Write-Host "4 - Sair"

    $opcao = Read-Host "Escolha"

    if ($opcao -eq "1"){

        $toner = Read-Host "Digite o toner"
        $quantidade = [int](Read-Host "Quantidade que chegou")

        $range = $sheet.Columns.Item(3)

        $celula = $range.Find($toner)

        if ($celula -ne $null){

            $linha = $celula.Row

            $atual = [int]$sheet.Cells.Item($linha,4).Value2
            $sheet.Cells.Item($linha,4) = $atual + $quantidade

            Registrar-Historico "ENTRADA" $toner $quantidade

            Write-Host "Estoque atualizado!"
        }
        else{

            Write-Host "Toner não encontrado!"
        }

        $workbook.Save()
    }

    elseif ($opcao -eq "2"){

        $toner = Read-Host "Digite o toner"
        $quantidade = [int](Read-Host "Quantidade retirada")

        $range = $sheet.Columns.Item(3)

        $celula = $range.Find($toner)

        if ($celula -ne $null){

            $linha = $celula.Row

            $atual = [int]$sheet.Cells.Item($linha,4).Value2

            if (($atual - $quantidade) -lt 0){

                Write-Host "ERRO: estoque insuficiente!"
            }
            else{

                $sheet.Cells.Item($linha,4) = $atual - $quantidade

                Registrar-Historico "SAIDA" $toner $quantidade

                Write-Host "Saida registrada!"
            }
        }
        else{

            Write-Host "Toner não encontrado!"
        }

        $workbook.Save()
    }

    elseif ($opcao -eq "3"){

        $linhas = $sheet.UsedRange.Rows.Count

        Write-Host ""
        Write-Host "ESTOQUE ATUAL"

        for ($i=2; $i -le $linhas; $i++){

            $imp = $sheet.Cells.Item($i,1).Text
            $ton = $sheet.Cells.Item($i,3).Text
            $qtd = $sheet.Cells.Item($i,4).Text

            Write-Host "$imp | $ton | $qtd"
        }
    }

    elseif ($opcao -eq "4"){
        break
    }
}

$workbook.Close()
$excel.Quit()
